# Sao chép thành file .env và điền giá trị thật:
#   copy .env.example .env   (Windows: copy .env.example .env)
#
# DATABASE_URL: Neon / Postgres (postgres://, postgresql:// hoặc jdbc:postgresql://)
# ADMIN_PASSWORD: secret ký HMAC (header X-Timestamp + X-Signature)

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
